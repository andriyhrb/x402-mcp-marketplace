# x402 MCP Gateway — env template
# Read by gateway/src/index.js + payment-verifier.js

# Anchor program (devnet)
PROGRAM_ID=DZEGM4VV5uoLyQaQ9HS638yTdkGVgpxvGUdCNP81qpbx

# Solana RPC — Helius devnet recommended
GATEWAY_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# CORS — comma-separated list of allowed origins (frontend URLs)
