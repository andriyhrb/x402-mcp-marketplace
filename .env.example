# x402 MCP Marketplace
# split: root .env (anchor cli + gateway), web/.env.local (Next.js)

# ── anchor + on-chain ──
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json
PROGRAM_ID=

# ── helius rpc ──
# free tier devnet key — https://dev.helius.xyz
HELIUS_API_KEY=
HELIUS_RPC=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# ── stablecoin ──
# Solana mainnet USDC mint (public address — paste the devnet mock for local)
USDC_MINT=

# ── gateway runtime ──
GATEWAY_PORT=4040
# requests per minute per wallet — soft cap, returns 429 with retry-after
RATE_LIMIT_WINDOW=60

# ── frontend ──
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_PROGRAM_ID=
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4040
